# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# === AI Model Providers ===
# At least ONE of these must be set:

# OpenRouter (recommended — access to 100+ models through single API)
OPENROUTER_API_KEY=your_openrouter_api_key

# Anthropic (direct access to Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Agent Settings ===
AGENT_NAME=Hermes Zera
LOG_LEVEL=INFO

# === Agent OS (optional — auto-detected from repo root) ===
# AGENT_OS_PATH=../../repos/packages/agent-os/src
