# LightRAG Environment Configuration

# Data directory for storing documents, chunks, embeddings
LIGHTRAG_DATA_DIR=./data

# Enable debug output
LIGHTRAG_DEBUG=false

# Number of top results to retrieve
LIGHTRAG_TOP_K=5

# Embedding provider: local | openai | gemini
LIGHTRAG_EMBEDDING_PROVIDER=local

# Generation provider: ollama | openai | gemini | qwen
LIGHTRAG_GENERATOR_PROVIDER=ollama

# Model for generation
LIGHTRAG_GENERATOR_MODEL=qwen2.5-coder:7b

# API key (for OpenAI/Gemini providers)
# LIGHTRAG_API_KEY=your-api-key-here

# API endpoint (for custom endpoints)
# LIGHTRAG_ENDPOINT=https://your-endpoint.com
