{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antigravity.dev/schemas/telegram/fulfillment-event.schema.json",
  "title": "TelegramFulfillmentEvent",
  "type": "object",
  "required": ["event_id", "order_id", "status", "occurred_at", "idempotency_key"],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "processing", "fulfilled", "failed", "recoverable"]
    },
    "resource_type": {
      "type": "string"
    },
    "resource_id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
