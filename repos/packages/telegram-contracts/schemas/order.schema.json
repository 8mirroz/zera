{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antigravity.dev/schemas/telegram/order.schema.json",
  "title": "TelegramOrder",
  "type": "object",
  "required": ["order_id", "user_id", "surface", "currency", "amount_minor", "status", "created_at"],
  "properties": {
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "integer"
    },
    "chat_id": {
      "type": "integer"
    },
    "surface": {
      "type": "string",
      "enum": ["bot", "miniapp", "composite"]
    },
    "currency": {
      "type": "string",
      "minLength": 1
    },
    "amount_minor": {
      "type": "integer",
      "minimum": 0
    },
    "provider_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["created", "pending", "confirmed", "fulfilled", "failed", "recoverable"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
