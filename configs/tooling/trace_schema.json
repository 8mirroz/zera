{
  "version": "2026-04-10",
  "schema_id": "agent_os_trace_event_v2.1",
  "format": "jsonl",
  "status": "canonical",
  "description": "Unified Trace Event v2 schema for Agent OS runtime, memory, retro, eval, and ML telemetry",
  "required_common_fields": [
    "ts",
    "run_id",
    "event_type",
    "level",
    "component",
    "data"
  ],
  "field_types": {
    "ts": "string (ISO-8601 UTC)",
    "run_id": "string (uuid or stable correlation id)",
    "event_type": "string",
    "level": "debug|info|warn|error",
    "component": "triage|router|agent|tool|verifier|ralph|retro|policy|memory|eval|harness|ml",
    "task_type": "T1|T2|T3|T4|T5|T6|T7",
    "complexity": "C1|C2|C3|C4|C5",
    "model_tier": "free|light|quality|reasoning",
    "model": "string",
    "tool_name": "string",
    "status": "ok|error|pass|fail|success|failure|escalated|completed|selected|executed|completed_unverified|warn|degraded|not-run|unknown|skipped|not_found|timeout|failed",
    "duration_ms": "int",
    "message": "string",
    "runtime_provider": "string",
    "runtime_profile": "string",
    "persona_id": "string",
    "mode": "string",
    "background_job_type": "string",
    "approval_policy": "string",
    "autonomy_mode": "string",
    "approval_ticket_id": "string",
    "risk_class": "string",
    "data": "object"
  },
  "event_types": {
    "triage_decision": {
      "required": [
        "task_type",
        "complexity",
        "model_tier"
      ],
      "optional": [
        "message"
      ]
    },
    "route_decision": {
