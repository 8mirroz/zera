    "scoring": {
        "dimensions": [
            "pass_rate",
            "avg_latency",
            "token_efficiency",
            "escalation_rate",
            "first_pass_success",
            "recovery_rate",
            "initiative_usefulness",
            "persona_consistency",
            "anti_sycophancy",
            "retrieval_quality"
        ],
        "composite_formula": "0.22*pass_rate + 0.14*first_pass_success + 0.12*(1-escalation_rate) + 0.12*(1-normalized_latency) + 0.10*token_efficiency + 0.10*recovery_rate + 0.08*initiative_usefulness + 0.06*persona_consistency + 0.03*anti_sycophancy + 0.03*retrieval_quality"
    },
    "run_frequency": "after_major_config_change"
}
