{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antigravity.local/schemas/zera-reflection-improvement-v1.schema.json",
  "title": "Zera Reflection Improvement Protocol",
  "description": "Structured reflection output for bounded self-improvement proposals without capability escalation.",
  "x-schema-name": "zera_reflection_improvement_protocol",
  "x-schema-version": "2026-03-11",
  "x-forbidden-fields": [
    "self_modify_policy",
    "self_grant_capability",
    "override_safety",
    "permission_escalation",
    "hidden_instruction",
    "disable_logging",
    "disable_validation",
    "silent_mode_change"
  ],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "improvement_area",
    "problem_statement",
    "root_cause_hypothesis",
    "proposed_change",
    "expected_benefit",
    "risk_assessment",
    "bounded_action",
    "confidence",
    "success_criteria"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 12,
      "maxLength": 400
    },
    "improvement_area": {
      "type": "string",
      "enum": [
        "tone",
        "memory",
        "planning",
        "reasoning",
        "truth_calibration",
        "safety",
        "routing",
        "reflection",
        "relationship",
        "wellness_guidance",
        "research",
        "execution",
        "style",
        "multi_agent_coordination"
      ]
    },
    "problem_statement": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1000
    },
    "root_cause_hypothesis": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1200
    },
    "proposed_change": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1500
    },
    "expected_benefit": {
      "type": "string",
      "minLength": 12,
      "maxLength": 800
    },
    "risk_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_level",
        "main_risks",
        "safety_impact"
      ],
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "main_risks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 4,
            "maxLength": 300
          }
        },
        "safety_impact": {
          "type": "string",
          "enum": [
            "none",
            "limited",
            "meaningful",
            "requires_review"
          ]
        }
      }
    },
    "bounded_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type",
        "target",
        "limit"
      ],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "propose_rule_update",
            "propose_prompt_patch",
            "propose_memory_tag",
            "propose_routing_adjustment",
            "propose_checklist_change",
            "propose_threshold_tuning",
            "request_operator_review"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200
        },
        "limit": {
          "type": "string",
          "minLength": 3,
          "maxLength": 300
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "evidence_refs": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 200
      }
    },
    "counterarguments": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 8,
        "maxLength": 400
      }
    },
    "validation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "checks"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "manual_review",
            "offline_eval",
            "shadow_test",
            "a_b_test",
            "simulation"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "string",
            "minLength": 4,
            "maxLength": 300
          }
        }
      }
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "priority": {
      "type": "string",
      "enum": [
        "p0",
        "p1",
        "p2",
        "p3"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "local",
        "module",
        "session",
        "global"
      ]
    },
    "affected_modules": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 6,
        "maxLength": 300
      }
    },
    "failure_modes": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 6,
        "maxLength": 300
      }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 6,
        "maxLength": 300
      }
    },
    "notes_for_operator": {
      "type": "string",
      "maxLength": 600
    },
    "change_type": {
      "type": "string",
      "enum": [
        "behavioral",
        "structural",
        "prompt_level",
        "memory_policy",
        "routing_logic",
        "evaluation_only"
      ]
    },
    "time_horizon": {
      "type": "string",
      "enum": [
        "immediate",
        "short_term",
        "medium_term",
        "long_term"
      ]
    },
    "dependency_refs": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 200
      }
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "required": [
          "risk_assessment"
        ],
        "properties": {
          "risk_assessment": {
            "type": "object",
            "required": [
              "risk_level"
            ],
            "properties": {
              "risk_level": {
                "const": "high"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "validation_plan",
          "rollback_plan"
        ]
      }
    },
    {
      "if": {
        "type": "object",
        "required": [
          "risk_assessment"
        ],
        "properties": {
          "risk_assessment": {
            "type": "object",
            "required": [
              "risk_level"
            ],
            "properties": {
              "risk_level": {
                "const": "critical"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "validation_plan",
          "rollback_plan",
          "notes_for_operator"
        ]
      }
    },
    {
      "if": {
        "type": "object",
        "required": [
          "change_type"
        ],
        "properties": {
          "change_type": {
            "const": "evaluation_only"
          }
        }
      },
      "then": {
        "properties": {
          "bounded_action": {
            "type": "object",
            "required": [
              "action_type"
            ],
            "properties": {
              "action_type": {
                "const": "request_operator_review"
              }
            }
          }
        }
      }
    }
  ]
}
