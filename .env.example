GITHUB_PERSONAL_ACCESS_TOKEN=
CONTEXT7_API_KEY=
NOTION_TOKEN=
COMPOSIO_API_KEY=
MAGIC_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
SUPABASE_ACCESS_TOKEN=
STITCH_API_KEY=
QDRANT_API_KEY=

# Optional: agent-os MemoryStore backend (default JSONL, optional memU Cloud hybrid)
MEMORY_BACKEND=jsonl
MEMU_API_KEY=
MEMU_BASE_URL=https://api.memu.so
MEMU_USER_ID=antigravity-core
MEMU_AGENT_ID=agent-os-memory-store
MEMU_HTTP_TIMEOUT_SECONDS=5
MEMU_FAIL_OPEN=true
HF_TOKEN=

# Obsidian Vault Integration
# Default: project-local vault at antigravity-core/vault/
# Override to use external vault: ~/antigravity-vault
VAULT_PATH=./vault
SMART_CONNECTIONS_MCP_PATH=~/smart-connections-mcp

# Design System Engine
DESIGN_SYSTEM_DATA_PATH=repos/packages/design-system/data

# Agent Memory Layers
# HOT:  .agents/memory/working_memory.json   (session context, 24h TTL)
# WARM: .agents/skills/, .agents/memory/build-library/ (BM25 indexed)
# COLD: $VAULT_PATH                          (semantic embeddings + graph)

# NotebookLM integration (agent-os core lane)
# CI-first auth: prefer NOTEBOOKLM_AUTH_JSON secret.
# Local fallback: set NOTEBOOKLM_HOME and run `notebooklm login`.
NOTEBOOKLM_AUTH_JSON=
NOTEBOOKLM_HOME=
NOTEBOOKLM_LOG_LEVEL=WARNING
NOTEBOOKLM_DEFAULT_RETRY=3
NOTEBOOKLM_DEFAULT_TIMEOUT=300

# LLM Providers (Free stack defaults)
GEMINI_API_KEY=
CLOUDFLARE_API_TOKEN=
# Optional: low-latency provider (enable if integrating)
GROQ_API_KEY=
